{
    "manifest_version": 3,
    "name": "Clean Search",
    "version": "1.0",
    "description": "Automatically removes AI Overviews and summaries from search results.",
    "permissions": ["storage", "activeTab"],
    "host_permissions": [
        "*://*.google.com/*",
        "*://*.bing.com/*"
    ],
    "content_scripts": [
        {
        "matches": ["*://*.google.com/*", "*://*.bing.com/*"],
        "js": ["content.js"],
        "run_at": "document_start"
        }
    ],
    "action": {
        "default_popup": "popup.html",
        "default_icon": {
        }
    }
}